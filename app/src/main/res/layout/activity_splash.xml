<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <TextView
        android:id="@+id/tvAppTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MovEase"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="#1976D2"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="80dp"/>

    <!-- Left house -->
    <ImageView
        android:id="@+id/ivHouseLeft"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/ic_house"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:layout_marginStart="40dp"/>

    <!-- Right house -->
    <ImageView
        android:id="@+id/ivHouseRight"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:src="@drawable/ic_house"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:layout_marginEnd="40dp"/>

    <!-- Truck (starts near left house, will move to right house) -->
    <ImageView
        android:id="@+id/ivTruck"
        android:layout_width="72dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_truck"
        android:layout_alignBottom="@id/ivHouseLeft"
        android:layout_marginStart="80dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Moving made simple"
        android:textSize="16sp"
        android:textColor="#888"
        android:layout_below="@id/ivTruck"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="24dp"/>
</RelativeLayout>