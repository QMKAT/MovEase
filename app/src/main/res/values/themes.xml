<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme (Material Components Light, no ActionBar) -->
    <style name="Theme.MovEase" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>

        <!-- Secondary brand color (accent) -->
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/primary_dark</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Background and surface -->
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>

        <!-- Status bar -->
        <item name="android:statusBarColor" tools:targetApi="l">@color/status_bar</item>

        <!-- Rounded corners for a modern feel -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.MovEase.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.MovEase.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.MovEase.Large</item>
    </style>

    <!-- Shape styles -->
    <style name="ShapeAppearance.MovEase.Small" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>
    <style name="ShapeAppearance.MovEase.Medium" parent="ShapeAppearance.MaterialComponents.MediumComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>
    <style name="ShapeAppearance.MovEase.Large" parent="ShapeAppearance.MaterialComponents.LargeComponent">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>
</resources>